# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/attention_markets

# Twitter API v2 (optional — system works YouTube-only without it)
TWITTER_BEARER_TOKEN=

# Reddit API (optional — system works YouTube-only without it)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# YouTube Data API v3 (REQUIRED)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Attention Index Configuration
ATTENTION_TOPICS=Solana,AI
ATTENTION_UPDATE_INTERVAL_MINUTES=5
ATTENTION_TIME_WINDOW_HOURS=6
ATTENTION_HALF_LIFE_MINUTES=90

# Solana / Switchboard (optional — enables on-chain oracle push)
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Server
PORT=3000
NODE_ENV=production
