{
  "name": "attention-markets",
  "version": "1.0.0",
  "description": "Real-time attention oracle for Solana prediction markets",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc && cp src/database/*.sql dist/database/ && mkdir -p dist/database/migrations && cp src/database/migrations/*.sql dist/database/migrations/",
    "start": "node dist/server.js",
    "test": "jest",
    "migrate": "ts-node src/database/migrate.ts",
    "migrate:prod": "node dist/database/migrate.js",
    "test:collect": "ts-node test-collection.ts",
    "oracle:read": "ts-node scripts/read-oracle.ts",
    "oracle:monitor": "ts-node scripts/monitor-feeds.ts",
    "test:collectors": "ts-node tests/test-new-collectors.ts",
    "test:index": "ts-node tests/test-full-index.ts",
    "anchor:push": "ts-node scripts/push-doa-onchain.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "@switchboard-xyz/common": "^5.7.0",
    "@switchboard-xyz/on-demand": "^3.9.0",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.10.0",
    "apify-client": "^2.9.0",
    "axios": "^1.13.5",
    "bs58": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "google-trends-api": "^4.9.2",
    "googleapis": "^140.0.0",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "typescript": "^5.0.0",
    "winston": "^3.11.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0"
  }
}
